generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  role      Role     @default(STUDENT)
  grade     String?
  level     Level?
  password  String
  createdAt DateTime @default(now())

  agendaEntries      AgendaEntry[]
  grades             Grade[]
  gradeGoals         GradeGoal[]
  studentAttendance  StudentAttendance[]
  events             Event[]             @relation("EventAuthor")
  announcements      Announcement[]      @relation("AnnouncementAuthor")
  interactionsProfile    InteractionsProfile?
  sentFriendRequests     FriendRequest[]      @relation("FriendRequestFrom")
  receivedFriendRequests FriendRequest[]      @relation("FriendRequestTo")
  studyGroupsOwned       StudyGroup[]         @relation("StudyGroupOwner")
  studyGroupMemberships  StudyGroupMember[]   @relation("StudyGroupMembership")
  studyGroupMessages     StudyGroupMessage[]  @relation("StudyGroupAuthor")

  @@unique([name, grade], name: "nameGrade")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Level {
  MEDIO
  FUNDAMENTAL
}

model AgendaEntry {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  timeSlot   String
  activity   String?
  customText String?
  color      String?  @default("#2563eb")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, date, timeSlot])
}

model Grade {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject          String
  bimester         Int
  nota             Float?
  faltas           Int      @default(0)
  ac               Float    @default(0)
  aulasMinistradas Int      @default(50)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, subject, bimester])
}

model GradeGoal {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  bimester  Int
  metaNota  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, subject, bimester])
}

enum EventType {
  PROVA
  TRABALHO
  EVENTO
  REUNIAO
  FERIADO
  OUTRO
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  date        DateTime  @db.Date
  type        EventType @default(EVENTO)
  grade       String? // sala alvo; null = todas as turmas
  createdById Int
  createdBy   User      @relation("EventAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([date])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  grade       String? // sala alvo; null = todas as turmas
  pinned      Boolean  @default(false)
  createdById Int
  createdBy   User     @relation("AnnouncementAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
}

enum NewsCategory {
  ENEM
  ENEM_TREINEIRO
  VESTIBULAR
  VESTIBULINHO
  GERAL
}

model StudentNews {
  id         Int          @id @default(autoincrement())
  title      String
  summary    String
  sourceName String
  sourceUrl  String
  category   NewsCategory
  targetYears Int[]       @default([])
  region     String       @default("Bauru")
  opensAt    DateTime?
  closesAt   DateTime?
  highlight  Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model InteractionsProfile {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar    String
  hat       String   @default("none")
  top       String   @default("none")
  accessory String   @default("none")
  bg        String   @default("mint")
  createdAt DateTime @default(now())
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model FriendRequest {
  id          Int                 @id @default(autoincrement())
  fromUserId  Int
  fromUser    User                @relation("FriendRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    Int
  toUser      User                @relation("FriendRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  respondedAt DateTime?

  @@unique([fromUserId, toUserId])
}

model StudyGroup {
  id        Int      @id @default(autoincrement())
  name      String
  emoji     String   @default("🌿")
  subject   String?
  ownerId   Int
  owner     User     @relation("StudyGroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  members  StudyGroupMember[]
  messages StudyGroupMessage[]
}

model StudyGroupMember {
  id       Int        @id @default(autoincrement())
  groupId  Int
  group    StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   Int
  user     User       @relation("StudyGroupMembership", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime   @default(now())

  @@unique([groupId, userId])
}

model StudyGroupMessage {
  id        Int        @id @default(autoincrement())
  groupId   Int
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    Int
  user      User       @relation("StudyGroupAuthor", fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime   @default(now())

  @@index([groupId, createdAt])
}

model StudentAttendance {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year          Int
  bimester      Int
  diasFaltados  Int      @default(0)
  diasPrevistos Int      @default(50)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, year, bimester])
}
